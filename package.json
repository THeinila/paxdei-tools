{
  "name": "pax-planner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "FFXIV Teamcraft-style crafting & gathering planner for Pax Dei",
  "scripts": {
    "fetch:raw": "tsx scripts/fetch-raw.ts",
    "build:dataset": "tsx scripts/build-dataset.ts",
    "fetch:icons": "tsx scripts/fetch-icons.ts",
    "data": "npm run fetch:raw && npm run build:dataset && npm run fetch:icons",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "devalue": "^5.1.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  }
}
